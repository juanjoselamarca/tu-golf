# ─── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://[proyecto].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3003

# ─── IA ───────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Admin (fallback si no se usa columna role en profiles) ───────────────────
ADMIN_EMAILS=

# ─── Integraciones ────────────────────────────────────────────────────────────
GARMIN_CLIENT_ID=
GARMIN_CLIENT_SECRET=

# ─── Push Notifications (Web Push + VAPID) ───────────────────────────────────
# Generar ambas claves (una sola vez) con:
#   npx web-push generate-vapid-keys
# La public va en cliente (prefijo NEXT_PUBLIC_). La private y el contact
# email SOLO en server (no prefijo NEXT_PUBLIC_). Sin estas keys, push falla
# al cargar src/lib/push-notifications.ts en producción.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CONTACT_EMAIL=admin@golfersplus.com

# ─── E2E Tests (opcional — solo para correr tests autenticados) ───────────────
# Generado por: node --env-file=.env.local scripts/setup-e2e-user.mjs
# El user vive persistente en Supabase. Tests autenticados hacen login con él.
E2E_TEST_USER_EMAIL=e2e-test@golfersplus-test.local
E2E_TEST_USER_PASSWORD=...
