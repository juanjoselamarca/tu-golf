{
  "name": "golfersplus",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint --dir src",
    "lint:strict": "next lint --dir src --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:smoke": "playwright test --project=mobile-chromium e2e/smoke.spec.ts e2e/smoke-public-pages.spec.ts",
    "test:e2e:auth": "playwright test --project=mobile-chromium-auth",
    "test:e2e:ronda": "playwright test --project=mobile-chromium-auth e2e/ronda-flow.spec.ts",
    "test:e2e:setup-user": "node --env-file=.env.local scripts/setup-e2e-user.mjs",
    "audit": "tsx scripts/run-audit.ts",
    "audit:all": "tsx scripts/run-audit.ts all"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.79.0",
    "@google/generative-ai": "^0.24.1",
    "@iconify-json/fluent-emoji-high-contrast": "^1.2.5",
    "@sentry/nextjs": "^10.46.0",
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.44.4",
    "dotenv": "^17.3.1",
    "html2canvas": "^1.4.1",
    "jszip": "^3.10.1",
    "lucide-react": "^1.8.0",
    "next": "^14.2.35",
    "posthog-js": "^1.364.2",
    "qrcode.react": "^4.2.0",
    "react": "^18",
    "react-dom": "^18",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.0",
    "remark-gfm": "^4.0.1",
    "web-push": "^3.6.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/web-push": "^3.6.4",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "autoprefixer": "^10.0.1",
    "eslint": "^8",
    "eslint-config-next": "14.2.5",
    "jsdom": "^29.0.0",
    "postcss": "^8",
    "supabase": "^2.78.1",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.0"
  }
}
